# Production environment TEMPLATE for the pplCRM backend.
#
# Copy to a real, injected `.env.production` at deploy time (or map each line to a secret in your
# platform's secret manager) — NEVER commit real secrets. The backend loads it via Node's --env-file
# and validates it against apps/backend/src/env.ts, which crashes on boot if a *required* var is missing.
#
# Domain topology (see the deployment plan):
#   pplcrm.com        marketing site (Cloudflare Pages)
#   app.pplcrm.com    the CRM app (all orgs; tenant from session) + companion
#   api.pplcrm.com    THIS backend (tRPC at /, REST /api/*, OAuth /auth/*, webhooks, /d/*)
#   *.pplforms.com    per-org public submission surface (<org>.pplforms.com/{f,e,v,d})

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
# CORS is locked to APP_URL (the CRM origin). API_URL is this backend's own origin.
API_URL=https://api.pplcrm.com
APP_URL=https://app.pplcrm.com
# Base domain the per-org public submission subdomains hang off of.
PUBLIC_BASE_DOMAIN=pplforms.com
# Number of proxy hops in front of the app (so X-Forwarded-* is trusted). Set to your LB topology.
TRUST_PROXY=1

# ── Database ─────────────────────────────────────────────────────────────────
# Runtime role: least-privilege, CRUD only, CANNOT bypass RLS (must NOT be the owner role).
DB_HOST=CHANGE_ME.postgres.example
DB_PORT=5432
DB_NAME=pplcrm
DB_USER=pplcrm_app
DB_PASSWORD=CHANGE_ME
DB_SSL=true
# Connection pool ceiling (keep comfortably under Postgres max_connections; > WORKER_CONCURRENCY).
DB_POOL_MAX=20

# Migration/owner role (DDL). Used ONLY by the separate migrate step, not the serving process.
DB_MIGRATION_USER=pplcrm_owner
DB_MIGRATION_PASSWORD=CHANGE_ME
# Migrations run as a separate deploy step (npx tsx apps/backend/src/app/kyselyinit.ts) — NOT on boot.
MIGRATE_ON_BOOT=false

# ── Secrets ──────────────────────────────────────────────────────────────────
# REQUIRED. Signs internal tokens. Generate a strong random value (e.g. `openssl rand -base64 48`).
SHARED_SECRET=CHANGE_ME
# Encrypts stored Google/Microsoft OAuth tokens at rest. REQUIRED if any real mailbox is connected —
# unset = tokens stored as PLAINTEXT. Rotating it forces users to re-consent.
OAUTH_TOKEN_ENC_KEY=CHANGE_ME

# ALLOW_MOCK_PAYMENTS is intentionally ABSENT — it must never be truthy in production (it would let
# forged payment data through). Do not add it here.

# ── Object storage (Azure Blob) ──────────────────────────────────────────────
# Provision in the same region as the app + DB if honoring data residency.
AZURE_STORAGE_CONNECTION_STRING=CHANGE_ME
AZURE_STORAGE_CONTAINER=uploads

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=4

# ── Payments — Stripe billing (platform subscriptions) ───────────────────────
# Webhook to register at Stripe: https://api.pplcrm.com/api/billing/webhook
# Stripe Tax is enabled in code (automatic_tax on subscription Checkout) but needs one-time
# Dashboard setup or session creation FAILS: enable Tax, set origin address, preset SaaS tax
# code, default tax behavior = EXCLUSIVE (and on both plan Prices), add registrations.
# Full steps: deploy/PROD-CHECKLIST.md → "Stripe Tax".
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# Connect webhook endpoint ("Listen to events on connected accounts") for donations — a SECOND
# endpoint with its own secret, also at POST /api/donations/webhook. See PROD-CHECKLIST →
# "Stripe Connect (donations)" for the event list and Dashboard steps.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PLAN_GRASSROOTS_PRICE_ID=price_CHANGE_ME
STRIPE_PLAN_MOVEMENT_PRICE_ID=price_CHANGE_ME
# Platform application fee (percent) on Stripe card donations. Decided 2026-07-16: 1% — the
# campaign also pays Stripe's own processing fees directly (all-in ≈ 3.9% + 30¢ domestic).
DONATIONS_PLATFORM_FEE_PERCENT=1
# NOTE: donations no longer use tenant-entered Stripe keys — tenants onboard via Stripe Connect
# in-app (Workspace → Donations) and we store only their connected-account id. Donations stay
# fail-closed until a tenant sets donations.residency_acknowledged.

# ── Email — Postmark (transactional) ─────────────────────────────────────────
# Bounce/complaint webhook to register: https://api.pplcrm.com/api/postmark/webhook
POSTMARK_SERVER_TOKEN=CHANGE_ME
POSTMARK_FROM_EMAIL=hello@pplcrm.com
POSTMARK_WEBHOOK_TOKEN=CHANGE_ME

# ── Ops alerting ─────────────────────────────────────────────────────────────
# The ops watchdog cron emails failed-job/webhook/backlog digests here (via Postmark, directly).
# Unset = digests are only logged. Uptime alerting itself is Azure Monitor (infra/azure/main.bicep).
OPS_ALERT_EMAIL=CHANGE_ME
# Sentry backend error tracking (errors only, PII scrubbed in instrument.ts). Unset = disabled.
SENTRY_DSN=

# ── Email — SendGrid (newsletter/bulk) ───────────────────────────────────────
# Signed-event webhook to register: https://api.pplcrm.com/api/newsletters/webhook
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_WEBHOOK_VERIFICATION_KEY=CHANGE_ME
# Free-tier subuser that isolates free-plan sending reputation.
SENDGRID_FREE_TIER_SUBUSER=CHANGE_ME

# ── AI — Anthropic (newsletter preflight content review) ─────────────────────
# Optional: when unset, the deliverability check scores from the deterministic lint alone
# (fail-open) and the AI review is skipped.
# The AI review runs on EVERY server-side check (send gate + user-run, all plans) — the site
# advertises this. Spend stays cents/newsletter: content-hash caching + 30/h/tenant on user-run
# checks; send volume is bounded by plan caps.
ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_MODEL=claude-opus-4-8

# ── SMS — Twilio (companion verification codes) ──────────────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Google ───────────────────────────────────────────────────────────────────
# Backend geocoding key (separate from the browser VITE_GOOGLE_MAPS_API_KEY set at frontend build).
GOOGLE_MAPS_API_KEY=CHANGE_ME
# Gmail sync OAuth. Redirect must match Google Cloud console exactly.
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://api.pplcrm.com/auth/google/callback

# ── Microsoft (Graph mailbox sync) ───────────────────────────────────────────
# Redirect must match the Azure app registration exactly.
MS_CLIENT_ID=CHANGE_ME
MS_CLIENT_SECRET=CHANGE_ME
MS_TENANT_ID=common
MS_REDIRECT_URI=https://api.pplcrm.com/auth/ms/callback
