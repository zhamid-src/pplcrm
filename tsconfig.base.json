{
  "compileOnSave": false,
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@common": ["./libs/common/src/index.ts"],
      "@experiences/*": ["./apps/frontend/src/app/experiences/*"],
      "@frontend/*": ["./apps/frontend/src/app/*"],
      "@icons/*": ["./libs/uxcommon/src/components/icons/*"],
      "@pplcrm/uxcommon": ["./libs/uxcommon/src/index.ts"],
      "@uxcommon/*": ["./libs/uxcommon/src/*"],
      "apps/*": ["./apps/*"],
      "common/*": ["./libs/common/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
