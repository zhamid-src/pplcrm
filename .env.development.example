# Local development environment template for `nx serve backend`.
#
# setup.sh copies this to `.env.development` (which is gitignored) if that file
# doesn't already exist. You can also copy it by hand:
#
#     cp .env.development.example .env.development
#
# The backend loads it via Node's --env-file (see apps/backend/project.json).
# Values mirror the local DB + least-privilege role split that setup.sh
# provisions (pplcrm_app runtime / pplcrm_owner migrations). Under local `trust`
# auth the passwords are ignored, but the env schema requires them to be
# non-empty (apps/backend/src/env.ts).

# Server
HOST=localhost
PORT=3000
API_URL=http://localhost:3000
APP_URL=http://localhost:4200

# Database — runtime role (CRUD only)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pplcrm
DB_USER=pplcrm_app
DB_PASSWORD=dev_app_pw

# Database — migration/owner role (DDL); the app migrates on boot as this role.
DB_MIGRATION_USER=pplcrm_owner
DB_MIGRATION_PASSWORD=dev_owner_pw
MIGRATE_ON_BOOT=true

# Shared secret for signed internal tokens (required). Dev-only value — change it.
SHARED_SECRET=dev_shared_secret_change_me

# Allow the local mock payment paths (never set outside local dev).
ALLOW_MOCK_PAYMENTS=true
