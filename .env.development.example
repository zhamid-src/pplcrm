# Local development environment template for `nx serve backend`.
#
# setup.sh copies this to `.env.development` (which is gitignored) if that file
# doesn't already exist. You can also copy it by hand:
#
#     cp .env.development.example .env.development
#
# The backend loads it via Node's --env-file (see apps/backend/project.json).
# Values mirror the local DB + least-privilege role split that setup.sh
# provisions (pplcrm_app runtime / pplcrm_owner migrations). Under local `trust`
# auth the passwords are ignored, but the env schema requires them to be
# non-empty (apps/backend/src/env.ts).

# Server
# Note: no PORT here on purpose. Nx auto-loads this file for *frontend* serve too
# (configuration "development"), and the Angular dev-server lets a PORT env var
# override its configured 4200 — so PORT=3000 here hijacks the frontend port.
# The backend already defaults to 3000 (apps/backend/src/env.ts).
HOST=localhost
API_URL=http://localhost:3000
APP_URL=http://localhost:4200

# Database — runtime role (CRUD only)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pplcrm
DB_USER=pplcrm_app
DB_PASSWORD=dev_app_pw

# Database — migration/owner role (DDL); the app migrates on boot as this role.
DB_MIGRATION_USER=pplcrm_owner
DB_MIGRATION_PASSWORD=dev_owner_pw
MIGRATE_ON_BOOT=true

# Shared secret for signed internal tokens (required). Dev-only value — change it.
SHARED_SECRET=dev_shared_secret_change_me

# Allow the local mock payment paths (never set outside local dev).
ALLOW_MOCK_PAYMENTS=true

# --- Third-party API keys (all optional in dev; features degrade honestly) ---

# Google Maps — backend geocoding of household addresses (Geocoding API).
# The frontend map/autocomplete key is separate: set VITE_GOOGLE_MAPS_API_KEY
# in apps/frontend/.env.local (Vite only reads env files from apps/frontend/).
# Unset (or containing "mock") → geocode jobs fill deterministic dev coordinates.
#GOOGLE_MAPS_API_KEY=

# Stripe — billing/plan activation. Unset → mock payment paths (see
# ALLOW_MOCK_PAYMENTS above). If you set a real test key: subscription Checkout
# uses automatic_tax, so the test-mode Dashboard needs Stripe Tax enabled
# (origin address + exclusive tax behavior) or session creation fails — see
# deploy/PROD-CHECKLIST.md → "Stripe Tax".
#STRIPE_SECRET_KEY=
#STRIPE_WEBHOOK_SECRET=
#STRIPE_PLAN_GRASSROOTS_PRICE_ID=
#STRIPE_PLAN_MOVEMENT_PRICE_ID=

# Postmark — transactional email (signup verification, invites).
#POSTMARK_SERVER_TOKEN=
#POSTMARK_FROM_EMAIL=hello@pplcrm.com

# SendGrid — newsletter sending + event webhook.
#SENDGRID_API_KEY=
#SENDGRID_WEBHOOK_VERIFICATION_KEY=

# Twilio SMS (companion verification codes). Leave unset in dev — the SMS
# service logs a "[TWILIO DEV MOCK]" line instead of sending.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15550006789
